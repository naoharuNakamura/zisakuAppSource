<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zisakuapp.zisaku_backend.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.zisakuapp.zisaku_backend.model.User">
        <id property="userId" column="user_id" />
        <result property="userPassword" column="user_password" />
        <result property="userName" column="user_name" />
        <result property="userEmail" column="user_email" />
        <result property="userPhone" column="user_phone" />
    </resultMap>

    <select id="findByUserId" resultMap="UserResultMap">
        SELECT * FROM m_user WHERE user_id = #{userId}
    </select>

    <select id="findByUserEmail" resultMap="UserResultMap">
        SELECT * FROM m_user WHERE user_email = #{userEmail}
    </select>
    
    <select id="existsByUserEmail" resultMap="UserResultMap">
        SELECT COUNT(1) FROM m_user WHERE user_email = #{userEmail}
    </select>

    <insert id="insert" parameterType="com.zisakuapp.zisaku_backend.model.User" useGeneratedKeys="true" keyProperty="userId">
        INSERT INTO m_user (user_password, user_name, user_email, user_phone)
        VALUES (#{userPassword}, #{userName}, #{userEmail}, #{userPhone})
    </insert>

    <update id="update" parameterType="com.zisakuapp.zisaku_backend.model.User">
        UPDATE m_user
        <set>
            <if test="userPassword != null">user_password = #{userPassword},</if>
            <if test="userName != null">user_name = #{userName},</if>
            <if test="userEmail != null">user_email = #{userEmail},</if>
            <if test="userPhone != null">user_phone = #{userPhone},</if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <select id="countAllUsers" resultType="int">
        SELECT COUNT(*) FROM m_user
    </select>

    <select id="getAllEmails" resultType="string">
        SELECT user_email FROM m_user LIMIT 10
    </select>
</mapper>