<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zisakuapp.zisaku_backend.mapper.UserRestaurantMapper">

    <resultMap id="UserRestaurantResultMap" type="com.zisakuapp.zisaku_backend.model.UserRestaurant">
        <id column="user_id" property="id.userId"/>
        <id column="restaurant_id" property="id.restaurantId"/>
        
        <result column="is_favorite" property="isFavorite"/>
        <result column="user_memo" property="userMemo"/>
    </resultMap>

    <select id="findAll" resultMap="UserRestaurantResultMap">
        SELECT * FROM t_user_restaurant
    </select>

    <select id="findByIdUserId" resultMap="UserRestaurantResultMap">
        SELECT * FROM t_user_restaurant
        WHERE user_id = #{userId}
    </select>

    <select id="findByIdUserIdAndIdRestaurantId" resultMap="UserRestaurantResultMap">
        SELECT * FROM t_user_restaurant
        WHERE user_id = #{userId} AND restaurant_id = #{restaurantId}
    </select>

    <insert id="upsert" parameterType="com.zisakuapp.zisaku_backend.model.UserRestaurant">
        INSERT INTO t_user_restaurant (user_id, restaurant_id, is_favorite, user_memo)
        VALUES (#{id.userId}, #{id.restaurantId}, #{isFavorite}, #{userMemo})
        ON CONFLICT(user_id, restaurant_id) DO UPDATE SET
            is_favorite = excluded.is_favorite,
            user_memo = excluded.user_memo
    </insert>

    <delete id="deleteByIdUserIdAndIdRestaurantId">
        DELETE FROM t_user_restaurant
        WHERE user_id = #{userId} AND restaurant_id = #{restaurantId}
    </delete>

</mapper>